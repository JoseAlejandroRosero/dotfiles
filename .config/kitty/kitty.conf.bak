# Font, my favorite font is maple mono :)
font_family Maple Mono NF Mono

# Make the cursor shape a beam
shell_integration no-cursor
cursor_shape beam
cursor_shape_unfocused unchanged
cursor_beam_thickness 1.0
cursor_trail 2000
cursor_trail_decay 0.2 0.5
cursor_trail_start_threshold 5

#urls
url_color #91e820
url_style straight
show_hyperlink_targets yes

# tab powerline
tab_bar_style powerline
tab_title_max_length 8

# Windows and Layouts
enabled_layouts splits:split_axis=auto

# Window borders and margins
window_border_width 1pt
inactive_text_alpha 0.8

# Splits Layour actions (move windows using VIM keys)
map ctrl+f2 detach_window
map ctrl+f3 detach_window new-tab
map ctrl+f4 detach_window ask
map ctrl+shift+f2 detach_tab
map ctrl+shift+f4 detach_tab ask
map f5 layout_action rotate 180
map f6 layout_action rotate 270
map f7 layout_action rotate
map alt+h move_window left
map alt+k move_window up
map alt+j move_window down
map alt+l move_window right
map ctrl+h neighboring_window left
map ctrl+j neighboring_window bottom
map ctrl+k neighboring_window top
map ctrl+l neighboring_window right
map ctrl+f9 close_other_windows_in_tab

# Tall layout mirror toggle
map ctrl+/ layout_action mirror toggle
# bias for both layouts
map ctrl+. layout_action bias 75
# selt resizes to default
map ctrl+home resize_window reset


# Padding
window_padding_width 7

# Scroll back up to 3000 lines.
scrollback_lines 3000

#Default font size.
font_size 11

# Just a keybind to change font size to your liking, it's CTRL + scroll wheel up or down.
map ctrl+shift+plus change_font_size all +1.0
map ctrl+shift+minus change_font_size all -1.0

# Set default shell to fish
shell fish

# Set default editor as nvim
editor vim

# Colors from pywal16
cursor               #fff

selection_background #b6a5a1
selection_foreground #000

background           #201e1d
foreground           #fff

#color0               #2b2135
#color8               #92fcfa
#color1               #fc4649
#color9               #fc4649
#color2               #c4e881
#color10              #c4e881
#color3               #AC82E9
#color11              #AC82E9
#color4               #7b91fc
#color12              #7b91fc
#color5               #f3fc7b
#color13              #f3fc7b
#color6               #8F56E1
#color14              #8F56E1
#color7               #fc92fc
#color15              #e82091

#tab foregrounds
active_tab_foreground #000
active_tab_background #c5ba9f
inactive_tab_foreground #c5ba9f
inactive_tab_background #635d50

inactive_border_color #b7b3aa
active_border_color #383637
bell_border_color #b2a07d

# Background opacity, set to 0 if you want blur/transparency.
background_opacity 0.75
