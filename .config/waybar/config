{
  "layer": "bot",
  "spacing": 0,
  "height": 0,
  "margin-bottom": 0,
  "margin-top": 0,
  "position": "top",
  "reload_style_on_change": true,
  "no-center":true,
  "modules-left": [
    "custom/power",
    "custom/swww",
    "ext/workspaces",
  ],
  "modules-right": [
    "mpd",
    "group/rightmenu",
    "clock",
	"tray"
  ],
  "custom/power": {
    "format" : "󰩤",
    "tooltip-format": "Power menu",
	"on-click": ""
  },
  "custom/swww" : {
    "format": "󰸉",
	"tooltip-format": "wallpaper picker",
	"on-click": "wallpaper-menu"
  },
  "ext/workspaces": {
    "format": "{icon}{name}",
    "format-icons": {
      "default": "",
      "active": "",
	  "urgent": ""
    },
    "on-click": "activate",
	"ignore-hidden": true,
    "sort-by-id": true
  },
  "mpd" : {
    "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon} {artist} - {album} - {title}",
    "format-disconnected": "Disconnected 󱘖 ",
    "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon} Stopped",
	"artist-len": 13,
	"album-len": 13,
	"title-len": 20,
    "consume-icons": {"on": " "},
    "random-icons": {"on": " "},
    "repeat-icons": {"on": " "},
    "single-icons": {"on": "󰲠 "},
    "state-icons": {
      "paused": " ",
      "playing": " "
      },
    "on-click": "setsid -wf kitty -e rmpc",
    "on-click-middle": "mpc toggle",
    "on-click-right": "setsid -wf kitty -e wiremix -m 100 --enforce-max-volume",
    "on-scroll-up": "mpc prev",
    "on-scroll-down": "mpc next",
  },
  "group/rightmenu": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "click-to-reveal": true 
    },
    "modules": [
      "network",
	  "memory",
      "bluetooth",
      "battery",
      "pulseaudio"
    ]
  },
  "tray": {
    "spacing": 10,
    "show-passive-items": true
  },
  "clock": {
    "format": "󰅐 {:%H:%M}",
    "tooltip-format": "<tt><span>{calendar}</span></tt>",
    "format-alt": " {:%x}",
    "timezone": "America/Bogota",
    "calendar": {
      "mode": "month",
      "mode-mon-col"  : 4,
      "on-scroll"     : 1,
      "on-click-right": "mode",
      "format": {
        "months":     "<span ><b>{}</b></span>",
        "days":       "<span ><b>{}</b></span>",
        "weekdays":   "<span ><b>{}</b></span>",
        "today":      "<span ><b>{}</b></span>"
        }
      },
      "actions": {
        "on-click-right": "mode",
        "on-scroll-up": "shift_up",
        "on-scroll-down": "shift_down"
        }
  },
  "network": {
    "format-wifi": "  {bandwidthDownBits}",
    "format-ethernet": "󰈁 {bandwidthDownBits}",
    "format-disconnected": "󰤮 No Network",
    "interval": 5
  },
  "pulseaudio": {
    "scroll-step": 5,
    "max-volume": 100,
	"on-click": "setsid -wf kitty -e wiremix",
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon} {volume}%",
    "format-icons": [
      "",
      "",
      " "
    ],
    "nospacing": 1,
    "format-muted": " "
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-plugged": "󰂄{capacity}%",
    "format-alt": "{icon} {time}",
    "format-full": "󱈑 {capacity}%",
    "on-click": "btop",
    "format-icons": [
      "󱊡",
      "󱊢",
      "󱊣"
    ]
  }, 
  "memory": {
                "interval": 30,
                "format": "{percentage}%",
				"on-click": "setsid -wf kitty -e btop",
				"max-length": 10
           },
  "bluetooth": {
      "format": "󰂯 {status}",
      "format-connected": "󰂯 {device_alias}",
      "format-disabled": "󰂲",
	  "on-click": "setsid -wf kitty -e bluetui",
      "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
      "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
  }
}
